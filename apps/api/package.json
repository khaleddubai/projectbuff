{
  "name": "@aegis/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp/entry.ts",
    "mcp:sse": "tsx src/mcp/sse.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:up": "npx prisma db push",
    "migrate:down": "echo 'Use prisma migrate diff for rollback planning'",
    "migrate:status": "npx prisma migrate status",
    "migrate:to": "echo 'Use npx prisma migrate dev for developing migrations'",
    "migrate:verify": "npx prisma validate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "archiver": "^7.0.0",
    "bullmq": "^5.77.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "openai": "^4.28.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^5.22.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pino": "^7.0.4",
    "@types/pino-http": "^5.8.4",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  }
}
