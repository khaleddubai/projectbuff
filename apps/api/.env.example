# AEGIS API — Environment Configuration
# Copy this to .env and fill in your values

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegis

# --- Authentication ---
# Set a master API key to enable authentication on all endpoints
# MASTER_API_KEY=your-secret-api-key
# Set to true to disable auth (development only)
# AUTH_DISABLED=true

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_ALL=true

# --- Encryption Key for at-rest secrets ---
# Used to encrypt API keys stored in the database. Change in production.
# ENCRYPTION_KEY=your-32-char-encryption-key-here

# --- Monitoring & Observability ---
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=debug
# Optional: write logs to a file (e.g., ./logs)
# LOG_DIR=./logs
# Enable Prometheus-compatible /metrics endpoint (default: true)
# ENABLE_METRICS=true
# Application version (injected at build time)
# APP_VERSION=1.0.0

# --- AI Provider: OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Embeddings / RAG (Semantic Search) ---
# Model for generating text embeddings (OpenRouter model path)
EMBEDDING_MODEL=openai/text-embedding-3-small
# Vector dimension (text-embedding-3-small = 1536, text-embedding-3-large = 3072)
# EMBEDDING_DIMENSIONS=1536
