# AEGIS — Environment Configuration
# Copy this to .env and fill in your values

# --- API Configuration ---
PORT=3001
DATABASE_PATH=./apps/api/aegis.db
NODE_ENV=development

# --- Authentication ---
# Set a master API key to enable authentication on all endpoints
# MASTER_API_KEY=your-secret-api-key
# Set to true to disable auth (development only)
# AUTH_DISABLED=true

# --- CORS ---
# Comma-separated list of allowed origins (production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Set to true to allow all origins (development only)
CORS_ALLOW_ALL=true

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Encryption Key for at-rest secrets ---
# Used to encrypt API keys stored in the database. MUST be at least 32 characters.
# ENCRYPTION_KEY=your-32-char-encryption-key-here

# --- AI Provider: OpenRouter (free tier available) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- AI Provider: NVIDIA NIM (alternative — free tier) ---
# NVIDIA_API_KEY=nvapi-your-key-here
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# --- AI Provider: OpenAI (fallback) ---
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Web App ---
NEXT_PUBLIC_API_URL=http://localhost:3001
